{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": false,
    "ignoreDeprecations": "5.0",
    "incremental": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
